    -- D features (time-delta/distance)
    D1, D2, D3, D4, D5, D6, D7, D8, D9, D10, D11, D12, D13, D14, D15,

    -- M features (encoded)
    M1_enc, M2_enc, M3_enc, M4_enc, M5_enc, M6_enc, M7_enc, M8_enc, M9_enc

FROM "fraud"."main"."clean_transactions"
  );

