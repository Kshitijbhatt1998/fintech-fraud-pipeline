# ── Fraud Detection Pipeline — Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in values.
# .env is git-ignored and NEVER committed.
#
# Most variables are optional — the pipeline runs locally without any of them.
# Comment out any service you are not using.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development        # development | staging | production
APP_VERSION=1.0.0          # used in Sentry release tracking

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
# Create a project at https://sentry.io and paste the DSN here.
# All scripts (dashboard, train, ingest) report errors to Sentry when set.
# SENTRY_DSN=<paste DSN from sentry.io — Settings > Projects > Client Keys>

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, find keys in Settings > API.
# The dashboard login gate activates only when both values are set.
# Password reset tokens expire after 1 hour (Supabase default JWT TTL).
# SUPABASE_URL=<paste Project URL from supabase.com — Settings > API>
# SUPABASE_ANON_KEY=<paste anon/public key from supabase.com — Settings > API>

# ── PostHog Analytics ─────────────────────────────────────────────────────────
# Dashboard tab views and CSV exports are tracked as server-side events.
# Landing page tracks page views via the JS snippet (key is set inline in HTML).
# POSTHOG_API_KEY=<paste API key from app.posthog.com — Project Settings>
# POSTHOG_HOST=https://us.i.posthog.com  # change to https://eu.i.posthog.com for EU hosting

# ── MLflow ────────────────────────────────────────────────────────────────────
# Defaults to local ./mlruns/ when not set.
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── HuggingFace (optional dataset publishing) ─────────────────────────────────
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Kaggle (optional dataset download) ────────────────────────────────────────
# Prefer storing in ~/.kaggle/kaggle.json instead of here.
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key

# ── Deployment (used by .github/workflows/deploy.yml) ────────────────────────
# These are set as GitHub Actions secrets, not in .env.
# DEPLOY_HOST=your-server-ip
# DEPLOY_USER=ubuntu
# DEPLOY_SSH_KEY=<contents of private key>
