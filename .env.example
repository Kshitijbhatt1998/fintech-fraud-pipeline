# ── Fraud Detection Pipeline — Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in values.
# .env is git-ignored and NEVER committed.
#
# Most variables are optional — the pipeline runs without them.

# ── HuggingFace (optional) ────────────────────────────────────────────────────
# Required only if you use `huggingface_hub` to publish the processed dataset.
# Get a token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MLflow (optional) ─────────────────────────────────────────────────────────
# Defaults to local ./mlruns directory if not set.
# Set to a remote URI for team-shared experiment tracking.
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── Kaggle (optional) ────────────────────────────────────────────────────────
# Used to download the IEEE-CIS dataset via Kaggle API.
# Store credentials in ~/.kaggle/kaggle.json instead of here.
# See: https://github.com/Kaggle/kaggle-api#api-credentials
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key
